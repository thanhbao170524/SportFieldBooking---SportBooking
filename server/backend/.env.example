# ================================================================
# Backend Environment Variables
# Copy this file: cp .env.example .env
# Then fill in your values
# ================================================================

# --- APP ---
NODE_ENV=development
PORT=3000

# --- DATABASE (Required) ---
DATABASE_URL="postgresql://YOUR_USER:YOUR_PASSWORD@localhost:5432/sports-booking?schema=public"

# --- JWT (Required) ---
JWT_SECRET="change-this-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# --- FRONTEND URL (for CORS & email links) ---
NEXT_PUBLIC_APP_URL=http://localhost:5173

# --- REDIS ---
REDIS_URL="redis://localhost:6379"

# --- SMTP (for password reset & notifications) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
EMAIL_USER=your-email@gmail.com

# --- SOCIAL AUTH ---
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- CLOUDINARY (image uploads) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- MAPBOX (maps) ---
NEXT_PUBLIC_MAPBOX_TOKEN=

# --- BOOKING ---
BOOKING_EXPIRE_MINUTES=5

# --- MOMO PAYMENT (Sandbox) ---
MOMO_V2_PARTNER_CODE=
MOMO_V2_ACCESS_KEY=
MOMO_V2_SECRET_KEY=
MOMO_V2_ENDPOINT="https://test-payment.momo.vn/v2/gateway/api/create"
MOMO_V2_REDIRECT_URL="http://localhost:5173/checkout?success=1"
MOMO_V2_IPN_URL="http://localhost:3000/api/payments/webhook"

# --- STRIPE ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# --- AI CHATBOT ---
GOOGLE_CLOUD_API_KEY=
GEMINI_API_KEY=