generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["fullTextSearchPostgres", "postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String          @id @default(cuid())
  email                String          @unique
  phone                String?         @unique
  passwordHash         String?
  fullName             String
  avatarUrl            String?
  role                 Role            @default(USER)
  isActive             Boolean         @default(true)
  isEmailVerified      Boolean         @default(false)
  googleId             String?         @unique
  facebookId           String?         @unique
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  lastLoginAt          DateTime?
  isVerified           Boolean         @default(false)
  deletedAt            DateTime?
  failedLoginAttempts  Int             @default(0)
  lastLoginIp          String?
  lastPasswordChangeAt DateTime?
  lockoutUntil         DateTime?
  auditLogs            AuditLog[]
  bookings             Booking[]
  customerProfiles     ClubCustomer[]
  ownedClubs           Club[]
  favoriteClubs        FavoriteClub[]
  favoritesCourts      FavoriteCourt[]
  notifications        Notification[]
  ownerProfile         OwnerProfile?
  passwordResets       PasswordReset[]
  reviews              Review[]
  sessions             Session[]
  profile              UserProfile?
  voucherUsages        VoucherUsage[]
  reports              Report[]
  comments             Comment[]

  @@map("users")
}

model UserProfile {
  id          String    @id @default(cuid())
  userId      String    @unique
  address     String?
  dateOfBirth DateTime?
  gender      String?
  bio         String?
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  ipAddress String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  isRevoked Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

model Club {
  id             String         @id @default(cuid())
  ownerId        String
  name           String
  slug           String         @unique
  description    String?
  address        String
  ward           String?
  district       String
  city           String
  latitude       Float?
  longitude      Float?
  phone          String?
  email          String?
  website        String?
  logoUrl        String?
  coverImageUrl  String?
  approvalStatus ApprovalStatus @default(PENDING)
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  slotDuration   Int            @default(60)
  deletedAt      DateTime?
  bookings       Booking[]
  amenities      ClubAmenity[]
  customers      ClubCustomer[]
  images         ClubImage[]
  owner          User           @relation(fields: [ownerId], references: [id])
  courts         Court[]
  favoredBy      FavoriteClub[]
  openingHours   OpeningHour[]
  posts          Post[]
  vouchers       Voucher[]

  /// Thông tin chuyển khoản hiển thị cho khách (theo từng CLB)
  transferBankName        String?
  transferAccountNumber   String?
  transferBeneficiaryName String?
  transferQrImageUrl      String?

  @@index([name])
  @@index([address])
  @@index([slug])
  @@map("clubs")
}

model ClubImage {
  id        String   @id @default(cuid())
  clubId    String
  url       String
  caption   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@map("club_images")
}

model OpeningHour {
  id        String   @id @default(cuid())
  clubId    String
  dayOfWeek Int
  openTime  DateTime @db.Time(6)
  closeTime DateTime @db.Time(6)
  isClosed  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([clubId, dayOfWeek])
  @@map("opening_hours")
}

model Amenity {
  id        String           @id @default(cuid())
  name      String           @unique
  icon      String?
  createdAt DateTime         @default(now())
  clubs     ClubAmenity[]
  services  BookingService[]

  @@map("amenities")
}

model ClubAmenity {
  id        String   @id @default(cuid())
  clubId    String
  amenityId String
  note      String?
  price     Decimal  @default(0) @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  amenity   Amenity  @relation(fields: [amenityId], references: [id], onDelete: Cascade)
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([clubId, amenityId])
  @@map("club_amenities")
}

model Court {
  id              String               @id @default(cuid())
  clubId          String
  name            String
  description     String?
  sportType       SportType
  status          CourtStatus          @default(ACTIVE)
  capacity        Int?
  surface         String?
  indoorOutdoor   String?
  sortOrder       Int                  @default(0)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  deletedAt       DateTime?
  bookings        Booking[]
  images          CourtImage[]
  pricings        CourtPricing[]
  club            Club                 @relation(fields: [clubId], references: [id], onDelete: Cascade)
  favoredBy       FavoriteCourt[]
  specialPricings SpecialDatePricing[]
  timeSlots       TimeSlot[]
  voucherCourts   VoucherCourt[]

  @@index([name])
  @@map("courts")
}

model CourtImage {
  id        String   @id @default(cuid())
  courtId   String
  url       String
  caption   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  court     Court    @relation(fields: [courtId], references: [id], onDelete: Cascade)

  @@map("court_images")
}

model CourtPricing {
  id           String   @id @default(cuid())
  courtId      String
  dayOfWeek    Int?
  pricePerHour Decimal  @db.Decimal(12, 2)
  label        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  startTime    DateTime @db.Time(6)
  endTime      DateTime @db.Time(6)
  court        Court    @relation(fields: [courtId], references: [id], onDelete: Cascade)

  @@map("court_pricings")
}

model SpecialDatePricing {
  id           String   @id @default(cuid())
  courtId      String
  specificDate DateTime @db.Date
  startTime    DateTime @db.Time(6)
  endTime      DateTime @db.Time(6)
  pricePerHour Decimal  @db.Decimal(12, 2)
  note         String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  court        Court    @relation(fields: [courtId], references: [id], onDelete: Cascade)

  @@map("special_date_pricings")
}

model TimeSlot {
  id           String         @id @default(cuid())
  courtId      String
  status       TimeSlotStatus @default(AVAILABLE)
  lockedBy     String?
  lockedAt     DateTime?
  note         String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  startTime    DateTime
  endTime      DateTime
  bookingItems BookingItem[]
  court        Court          @relation(fields: [courtId], references: [id], onDelete: Cascade)

  @@unique([courtId, startTime])
  @@map("time_slots")
}

model Booking {
  id             String                 @id @default(cuid())
  userId         String
  courtId        String?
  bookingCode    String                 @unique @default(cuid())
  status         BookingStatus          @default(PENDING)
  totalAmount    Decimal                @db.Decimal(12, 2)
  discountAmount Decimal                @default(0) @db.Decimal(12, 2)
  finalAmount    Decimal                @db.Decimal(12, 2)
  note           String?
  voucherId      String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  bookerName     String
  bookerPhone    String
  bookerEmail    String?
  clubId         String?
  deletedAt      DateTime?
  items          BookingItem[]
  services       BookingService[]
  statusHistory  BookingStatusHistory[]
  club           Club?                  @relation(fields: [clubId], references: [id])
  courts         Court?                 @relation(fields: [courtId], references: [id])
  user           User                   @relation(fields: [userId], references: [id])
  voucher        Voucher?               @relation(fields: [voucherId], references: [id])
  notifications  Notification[]
  payment        Payment?
  review         Review?

  @@map("bookings")
}

model BookingItem {
  id         String   @id @default(cuid())
  bookingId  String
  timeSlotId String
  price      Decimal  @db.Decimal(12, 2)
  createdAt  DateTime @default(now())
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  timeSlot   TimeSlot @relation(fields: [timeSlotId], references: [id])

  @@unique([bookingId, timeSlotId])
  @@map("booking_items")
}

model BookingService {
  id        String  @id @default(cuid())
  bookingId String
  amenityId String
  price     Decimal @db.Decimal(12, 2)
  quantity  Int     @default(1)
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  amenity   Amenity @relation(fields: [amenityId], references: [id])

  @@unique([bookingId, amenityId])
  @@map("booking_services")
}

model Payment {
  id              String        @id @default(cuid())
  bookingId       String        @unique
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  amount          Decimal       @db.Decimal(12, 2)
  transactionRef  String?       @unique
  bankName        String?
  accountNumber   String?
  beneficiaryName String?
  transferContent String?
  qrImageUrl      String?
  proofImageUrl   String?
  paidAt          DateTime?
  confirmedAt     DateTime?
  confirmedBy     String?
  note            String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  refundAmount    Decimal?      @db.Decimal(12, 2)
  refundNote      String?
  refundReason    String?
  refundRequestAt DateTime?
  refundReviewAt  DateTime?
  refundReviewBy  String?
  refundStatus    RefundStatus  @default(NONE)
  refundedAt      DateTime?
  booking         Booking       @relation(fields: [bookingId], references: [id])

  @@map("payments")
}

model Review {
  id        String        @id @default(cuid())
  userId    String
  bookingId String        @unique
  courtId   String?
  clubId    String?
  rating    Int
  comment   String?
  isVisible Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  deletedAt DateTime?
  images    ReviewImage[]
  booking   Booking       @relation(fields: [bookingId], references: [id])
  user      User          @relation(fields: [userId], references: [id])

  @@map("reviews")
}

model ReviewImage {
  id        String   @id @default(cuid())
  reviewId  String
  url       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@map("review_images")
}

model Voucher {
  id             String         @id @default(cuid())
  clubId         String?
  code           String         @unique
  title          String
  description    String?
  type           VoucherType
  value          Decimal        @db.Decimal(12, 2)
  minOrderAmount Decimal?       @db.Decimal(12, 2)
  maxDiscount    Decimal?       @db.Decimal(12, 2)
  usageLimit     Int?
  usagePerUser   Int            @default(1)
  usedCount      Int            @default(0)
  startDate      DateTime
  endDate        DateTime
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?
  bookings       Booking[]
  usages         VoucherUsage[]
  club           Club?          @relation(fields: [clubId], references: [id])
  /// Nếu rỗng: áp dụng mọi sân của CLB. Nếu có bản ghi: chỉ các sân được liệt kê (chỉ dùng cho voucher của CLB).
  applicableCourts VoucherCourt[]

  @@map("vouchers")
}

model VoucherCourt {
  id        String  @id @default(cuid())
  voucherId String
  courtId   String
  voucher   Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  court     Court   @relation(fields: [courtId], references: [id], onDelete: Cascade)

  @@unique([voucherId, courtId])
  @@map("voucher_courts")
}

model VoucherUsage {
  id        String   @id @default(cuid())
  voucherId String
  userId    String
  usedAt    DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  voucher   Voucher  @relation(fields: [voucherId], references: [id])

  @@unique([voucherId, userId])
  @@map("voucher_usages")
}

model FavoriteCourt {
  id        String   @id @default(cuid())
  userId    String
  courtId   String
  createdAt DateTime @default(now())
  court     Court    @relation(fields: [courtId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courtId])
  @@map("favorite_courts")
}

model FavoriteClub {
  id        String   @id @default(cuid())
  userId    String
  clubId    String
  createdAt DateTime @default(now())
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, clubId])
  @@map("favorite_clubs")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  bookingId String?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())
  booking   Booking?         @relation(fields: [bookingId], references: [id])
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Post {
  id            String     @id @default(cuid())
  clubId        String
  /// Đường dẫn ngắn để chia sẻ, duy nhất trong phạm vi CLB
  slug          String
  type          PostType
  status        PostStatus @default(ACTIVE)
  title         String
  content       String
  imageUrl      String?
  linkedCourtId String?
  linkedDate    DateTime?
  expiresAt     DateTime?
  viewCount     Int        @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?
  club          Club       @relation(fields: [clubId], references: [id], onDelete: Cascade)
  comments      Comment[]

  @@unique([clubId, slug])
  @@map("posts")
}

model ClubCustomer {
  id            String       @id @default(cuid())
  clubId        String
  userId        String
  tier          CustomerTier @default(NORMAL)
  totalBookings Int          @default(0)
  totalCancels  Int          @default(0)
  totalSpent    Decimal      @default(0) @db.Decimal(14, 2)
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  club          Club         @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clubId, userId])
  @@map("club_customers")
}

model OwnerProfile {
  id                 String         @id @default(cuid())
  userId             String         @unique
  idCardNumber       String?
  idCardFrontUrl     String?
  idCardBackUrl      String?
  businessLicenseUrl String?
  taxCode            String?
  bankName           String?
  bankAccountNumber  String?
  bankAccountName    String?
  cancellationPolicy String?
  kycStatus          ApprovalStatus @default(PENDING)
  kycReviewedAt      DateTime?
  kycReviewedBy      String?
  kycNote            String?
  /// Đã đóng modal giới thiệu phí duy trì (không chọn gói)
  billingIntroDismissedAt DateTime?
  /// Gói Subscription đã chọn: starter | growth | pro (snapshot cho billing sau này)
  subscriptionPlanKey   String?
  /// Add-on đã chọn (mảng id), ví dụ: ["advanced_reports","priority_support"]
  subscriptionAddons      Json?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("owner_profiles")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model BookingStatusHistory {
  id        String        @id @default(cuid())
  bookingId String
  status    BookingStatus
  note      String?
  changedBy String?
  createdAt DateTime      @default(now())
  booking   Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("booking_status_history")
}

model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@map("system_configs")
}

model Report {
  id         String       @id @default(cuid())
  reporterId String
  targetId   String
  targetType ReportTarget
  reason     String
  status     ReportStatus @default(PENDING)
  createdAt  DateTime     @default(now())

  reporter User @relation(fields: [reporterId], references: [id])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  content   String
  isHidden  Boolean  @default(false)
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id])
  user User @relation(fields: [userId], references: [id])
}

model VisitLog {
  id        String   @id @default(cuid())
  userId    String?
  path      String
  ip        String?
  createdAt DateTime @default(now())
}

model SystemLog {
  id        String   @id @default(cuid())
  level     String
  message   String
  context   Json?
  createdAt DateTime @default(now())
}

enum ReportTarget {
  USER
  POST
  REVIEW
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  REJECTED
}

enum Role {
  USER
  OWNER
  ADMIN
}

enum SportType {
  FOOTBALL
  BADMINTON
  TENNIS
  PICKLEBALL
  BASKETBALL
  VOLLEYBALL
  OTHER
}

enum CourtStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
  PENDING_APPROVAL
  SUSPENDED
}

enum TimeSlotStatus {
  AVAILABLE
  BOOKED
  LOCKED
}

enum BookingStatus {
  PENDING
  WAITING_PAYMENT
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentMethod {
  BANK_TRANSFER
  CREDIT_CARD
  MOMO
  VNPAY
  CASH
}

enum PaymentStatus {
  PENDING
  WAITING_PAYMENT
  CONFIRMED
  CANCELLED
  REFUNDED
}

enum RefundStatus {
  NONE
  REQUESTED
  APPROVED
  REJECTED
  COMPLETED
}

enum NotificationType {
  BOOKING_REMINDER
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  SCHEDULE_CHANGED
  PROMOTION
  SYSTEM
  NEWS_FEED
}

enum PostType {
  AVAILABLE_SLOT
  DISCOUNT
  EVENT
  TEAM_MATCHING
  ANNOUNCEMENT
}

enum PostStatus {
  ACTIVE
  HIDDEN
  EXPIRED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VoucherType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum CustomerTier {
  NORMAL
  SILVER
  GOLD
  VIP
}
